# AgentWeave Hub — environment configuration
# Copy this file to .env and fill in the values.

# SQLite database path (default: data/agentweave.db inside the container)
DATABASE_URL=sqlite+aiosqlite:///data/agentweave.db

# Port the Hub listens on (default: 8000)
AW_PORT=8000

# Bootstrap credentials — created automatically on first startup if no keys exist.
# Generate a secure key with: python -c "import secrets; print('aw_live_' + secrets.token_urlsafe(32))"
AW_BOOTSTRAP_API_KEY=aw_live_changeme_replace_with_secure_random_value
AW_BOOTSTRAP_PROJECT_ID=proj-default
AW_BOOTSTRAP_PROJECT_NAME=Default Project
